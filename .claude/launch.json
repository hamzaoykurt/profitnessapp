{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Build Debug APK",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "gradlew.bat assembleDebug"],
      "autoPort": true
    },
    {
      "name": "Build Release APK",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "gradlew.bat assembleRelease"],
      "autoPort": true
    },
    {
      "name": "Install & Run on Device",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "gradlew.bat installDebug"],
      "autoPort": true
    }
  ]
}
